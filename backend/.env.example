FLASK_APP=app.py
FLASK_ENV=development
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=chefasap

# Stripe API Keys
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# Stripe Webhook Secret
# Get this after setting up webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# JWT Secret Key
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
# Note: In production, make sure to use a strong, unique secret key and keep it secure!
# use 'python -c "import secrets; print(secrets.token_hex(32))"' to generate a secure random key and store to the JWT_SECRET_KEY in .env
# do this in the terminal and copy the output to the .env file. This will ensure your JWT tokens are secure and cannot be easily guessed or forged.


# Anthropic API Key (Menu & Event Planner LLM) - For test purposes, you can use a temporary key from on of the member's Anthropic console. 
# Get this from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_API_KEY_HERE

# --- TESTING VARIABLES ---
# Change this to your Render URL if you want to test the live server
TEST_API_URL=http://localhost:3000
TEST_CUSTOMER_ID=random_int_value
TEST_CHEF_ID=random_int_value
TEST_BOOKING_ID=random_int_value
TEST_EMAIL='your_email@gmail.com'
TEST_PASSWORD='your_password_here'
TEST_JWT_TOKEN=paste_your_temporary_token_here